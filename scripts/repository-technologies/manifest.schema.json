{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "repository", "commitSha", "summary", "technologies"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "repository": { "type": "string", "minLength": 3 },
    "commitSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "summary": { "type": "string", "minLength": 1, "maxLength": 400 },
    "technologies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "category", "evidence"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 80 },
          "category": { "type": "string", "enum": ["language", "framework", "library", "runtime", "database", "infrastructure", "tool", "service"] },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["path", "detail"],
              "properties": {
                "path": { "type": "string", "minLength": 1, "maxLength": 300 },
                "detail": { "type": "string", "minLength": 1, "maxLength": 300 }
              }
            }
          }
        }
      }
    }
  }
}
